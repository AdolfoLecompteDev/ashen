# ── Generated by Ashen ────────────────────────────────────────────────────
# Rewritten by the Theme tab (and by matugen in dynamic mode) on every scheme
# change, so tracking it means a diff every time the colors change.
# kitty only warns if the include is missing; the file reappears the first time
# a scheme is applied.
kitty/.config/kitty/ashen-colors.conf

# matugen writes these from the wallpaper on every change. They belong in
# ~/.config, not here — this only catches the case where stow folded the
# gtk-3.0/gtk-4.0 directories into symlinks back at the repo.
gtk/.config/gtk-3.0/gtk.css
gtk/.config/gtk-4.0/gtk.css

# ── Editor / OS noise ─────────────────────────────────────────────────────
*.swp
*.swo
*~
*.bak
*.orig
*.rej
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── Shell / runtime junk ──────────────────────────────────────────────────
*.log
.zcompdump*
__pycache__/
*.pyc
